# Environment Variables
# Copy this file to .env.local and fill in the values

# Auth (dev bypass)
AUTH_DEV_BYPASS=true
AUTH_DEV_EMAIL=your@email.com
AUTH_DEV_USER_ID=your-user-id

# Auth (production)
AUTH_AUDIENCE=base-account-client
AUTH_ISSUER=https://user.stringzhao.life
AUTH_JWKS_URL=https://user.stringzhao.life/.well-known/jwks.json

# DeepSeek AI
DEEPSEEK_API_KEY=<REPLACE_ME>
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# Speech-to-Text
STT_BASE_URL=<REPLACE_ME>
STT_MODEL=whisper-large-v3

# Database
POSTGRES_URL=<REPLACE_ME>

# Vercel
VERCEL_OIDC_TOKEN=<REPLACE_ME>

# Web Push
NEXT_PUBLIC_VAPID_PUBLIC_KEY=<REPLACE_ME>
VAPID_PRIVATE_KEY=<REPLACE_ME>
